# ── Required ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/yourdb?sslmode=require
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=15m
PORT=5000
NODE_ENV=production

# ── Email (Resend) ────────────────────────────────────────────
# RESEND_API_KEY=re_xxxx            (required for emails, get at https://resend.com)
# EMAIL_FROM=noreply@gritandgigs.in (default: noreply@gritandgigs.com)
# APP_URL=https://www.gritandgigs.in (used in email verification links)

# ── Supabase ──────────────────────────────────────────────────
# SUPABASE_URL=https://xxx.supabase.co   (required for Google OAuth & phone OTP)
# SUPABASE_ANON_KEY=eyJxxx               (required for Google OAuth & phone OTP)

# ── Razorpay ──────────────────────────────────────────────────
# RAZORPAY_KEY_ID=rzp_live_xxxx   (enable live payments)
# RAZORPAY_KEY_SECRET=rzp_secret_xxxx
# RAZORPAY_ACCOUNT_NUMBER=  (your Razorpay settlement account number for payouts)
# RAZORPAY_WEBHOOK_SECRET=   (webhook secret for payout status updates)
