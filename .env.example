# ── Required ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/yourdb?sslmode=require
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=15m
PORT=5000
NODE_ENV=production

